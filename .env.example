# ─── CodeSentinel Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://codesentinel:codesentinel123@localhost:5432/codesentinel

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Ollama (LLaMA 3) ────────────────────────────────────────────────────────
# Keep this as-is when running locally
OLLAMA_URL=http://localhost:11434

# ─── JWT Auth ────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-jwt-key-change-this

# ─── GitHub App (optional — needed only for PR auto-scan) ────────────────────
# Leave blank to use manual scan mode only
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ─── n8n (optional — for Slack/email escalation) ─────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook/codesentinel-alert
